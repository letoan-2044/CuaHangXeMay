@model WebsiteBanXeMay.Models.DatHangViewModel
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container-fluid my-5">
    <div class="row">
        <div class="col-12">
            <!-- HEADER -->
            <div class="d-flex justify-content-between align-items-center mb-5 pb-4 border-bottom">
                <h1 class="h2 fw-bold">
                    <i class="fas fa-file-invoice me-2"></i>
                    Chi tiết đơn hàng
                </h1>
                <a asp-action="Index" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left"></i> Trở lại
                </a>
            </div>

            @if (TempData["Loi"] != null)
            {
                <div class="alert alert-danger mb-4">@TempData["Loi"]</div>
            }

            @if (!Model.ChiTietGioHangs.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-file-invoice fa-5x text-muted mb-4 opacity-50"></i>
                    <h3 class="text-muted">Không có dữ liệu đơn hàng</h3>
                    <a asp-action="Index" class="btn btn-primary mt-3">Xem đơn hàng</a>
                </div>
            }
            else
            {
                <!-- THÔNG TIN ĐƠN HÀNG -->
                <div class="row mb-5">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0"><i class="fas fa-info me-2"></i>Thông tin</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Mã đơn hàng:</strong> @Model.DonHang.MaDonHang</p>
                                <p><strong>Điện thoại:</strong> @Model.DonHang.SoDienThoai</p>
                                <p><strong>Địa chỉ:</strong> @Model.DonHang.DiaChiGiaoHang</p>
                                <p><strong>Trạng thái:</strong> @Model.DonHang.TrangThai</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0"><i class="fas fa-receipt me-2"></i>Tổng kết</h5>
                            </div>
                            <div class="card-body text-center">
                                <h2 class="text-success mb-3">@Model.TongTien.ToString("N0") VNĐ</h2>
                                <p class="text-success fs-5">Miễn phí giao hàng</p>
                                <a asp-controller="SanPham" asp-action="Index" class="btn btn-primary w-100 mb-2">
                                    <i class="fas fa-shopping-bag me-2"></i>Mua tiếp
                                </a>
                                <button class="btn btn-outline-secondary w-100">In hóa đơn</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SẢN PHẨM -->
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Sản phẩm (@Model.ChiTietGioHangs.Count)</h5>
                    </div>
                    <div class="card-body p-0">
                        @foreach (var ct in Model.ChiTietGioHangs)
                        {
                            <div class="row align-items-center p-4 border-bottom">
                                <div class="col-md-2">
                                    <img src="~/images/@(ct.SanPham?.HinhAnh ?? "no-image.jpg")"
                                         class="img-fluid rounded" style="height:70px;object-fit:cover;" />
                                </div>
                                <div class="col-md-4">
                                    <h6 class="fw-bold">@ct.SanPham?.TenSanPham</h6>
                                    <small class="text-muted">Mã: @ct.SanPham?.MaSanPham</small>
                                </div>
                                <div class="col-md-3 text-center">
                                    <span class="badge bg-primary fs-6">@ct.SoLuong x</span>
                                </div>
                                <div class="col-md-3 text-end">
                                    <h5 class="fw-bold text-success">
                                        @((ct.SoLuong * (ct.SanPham?.Gia ?? 0)).ToString("N0")) VNĐ
                                    </h5>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>