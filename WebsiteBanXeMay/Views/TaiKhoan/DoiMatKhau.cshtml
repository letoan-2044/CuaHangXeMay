@model WebsiteBanXeMay.Models.ViewModels.DoiMatKhauViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-dark text-white text-center py-4 border-bottom border-dark-subtle">
                    <i class="fas fa-key fa-3x mb-3 opacity-75"></i>
                    <h3 class="mb-0 fw-bold">Đổi mật khẩu</h3>
                    <small class="opacity-75">Nhập mật khẩu cũ để đổi mật khẩu mới</small>
                </div>
                <div class="card-body p-5">
                    @if (TempData["success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" id="successAlert">
                            <i class="fas fa-check-circle me-2"></i>
                            @TempData["success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            @TempData["error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="DoiMatKhau" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-4"></div>

                        <div class="mb-4">
                            <label asp-for="MatKhauCu" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-lock text-warning"></i></span>
                                <input asp-for="MatKhauCu" class="form-control" type="password">
                            </div>
                            <span asp-validation-for="MatKhauCu" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="MatKhauMoi" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-lock-open text-success"></i></span>
                                <input asp-for="MatKhauMoi" class="form-control" type="password">
                            </div>
                            <span asp-validation-for="MatKhauMoi" class="text-danger"></span>
                        </div>

                        <div class="mb-5">
                            <label asp-for="XacNhanMatKhau" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-check-double text-info"></i></span>
                                <input asp-for="XacNhanMatKhau" class="form-control" type="password">
                            </div>
                            <span asp-validation-for="XacNhanMatKhau" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold py-3">
                                <i class="fas fa-sync-alt me-2"></i>Đổi mật khẩu mới
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Quay lại trang chủ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <!-- THAY THẾ TOÀN BỘ PHẦN ALERT + SCRIPT -->
    @if (TempData["success"] != null)
    {
        <script>
            // 🔥 ALERT COUNTDOWN TỰ ĐỘNG
            setTimeout(() => {
                const message = '@TempData["success"]';
                alert(message + '\n Tự động đăng xuất sau 3 giây...');

                setTimeout(() => {
                    window.location.href = '@Url.Action("DangXuat", "TaiKhoan")';
                }, 500);
            }, 100);
        </script>
    }
    }
}