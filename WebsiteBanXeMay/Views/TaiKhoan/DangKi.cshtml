@model WebsiteBanXeMay.Models.ViewModels.DangKiViewModels
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = "_Layout";
}

<!-- CSS riêng -->
<link rel="stylesheet" href="~/css/dangki.css" asp-append-version="true" />

<div class="dangki-container">
    <div class="dangki-card">
        <div class="dangki-header">
            <h2 class="dangki-title">
                <i class="fas fa-user-plus"></i> Đăng ký tài khoản
            </h2>
            <p class="dangki-subtitle">Tạo tài khoản mới để mua sắm</p>
        </div>

        <div class="dangki-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="DangKi" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="TenDangNhap" class="form-control @GetValidationClass("TenDangNhap")"
                                   id="TenDangNhap" placeholder="Tên đăng nhập" />
                            <label asp-for="TenDangNhap"></label>
                            <span asp-validation-for="TenDangNhap" class="invalid-feedback"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="SoDienThoai" class="form-control @GetValidationClass("SoDienThoai")"
                                   id="SoDienThoai" placeholder="Số điện thoại" />
                            <label asp-for="SoDienThoai"></label>
                            <span asp-validation-for="SoDienThoai" class="invalid-feedback"></span>
                        </div>
                    </div>
                </div>

                <div class="form-floating mt-4 mb-4">
                    <input asp-for="HoTen" class="form-control @GetValidationClass("HoTen")"
                           id="HoTen" placeholder="Họ và tên" />
                    <label asp-for="HoTen"></label>
                    <span asp-validation-for="HoTen" class="invalid-feedback"></span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="MatKhau" class="form-control @GetValidationClass("MatKhau") pe-5"
                                   id="MatKhau" placeholder="Mật khẩu" />
                            <label asp-for="MatKhau"></label>
                            <span asp-validation-for="MatKhau" class="invalid-feedback"></span>
                        </div>
                    </div>

                    <div class="col-md-6 position-relative">
                        <div class="form-floating">
                            <input asp-for="XacNhanMatKhau" class="form-control @GetValidationClass("XacNhanMatKhau") pe-5"
                                   id="XacNhanMatKhau" placeholder="Xác nhận mật khẩu" />
                            <label asp-for="XacNhanMatKhau"></label>
                            <span asp-validation-for="XacNhanMatKhau" class="invalid-feedback"></span>
                        </div>
                        <button type="button" class="btn-toggle-password" data-target="#XacNhanMatKhau">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="DiaChi" class="form-control @GetValidationClass("DiaChi")"
                           id="DiaChi" placeholder="Địa chỉ" />
                    <label asp-for="DiaChi">Địa chỉ (tùy chọn)</label>
                    <span asp-validation-for="DiaChi" class="invalid-feedback"></span>
                </div>

                <button type="submit" class="btn-dangki-primary w-100 mb-3">
                    <i class="fas fa-user-check me-2"></i>Đăng ký ngay
                </button>

                <a asp-controller="TaiKhoan" asp-action="DangNhap" class="btn-dangki-secondary w-100">
                    <i class="fas fa-sign-in-alt me-2"></i>Đã có tài khoản? Đăng nhập
                </a>
            </form>
        </div>

        <div class="dangki-footer">
            <small>
                Bằng cách đăng ký, bạn đồng ý với
                <a href="#">Điều khoản dịch vụ</a> và
                <a href="#">Chính sách bảo mật</a>
            </small>
        </div>
    </div>
</div>

@functions {
    string GetValidationClass(string propertyName)
    {
        if (!ViewData.ModelState.ContainsKey(propertyName)) return "";
        var state = ViewData.ModelState[propertyName];
        return state.Errors.Any() ? "is-invalid" : "is-valid";
    }
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/dangki.js" asp-append-version="true"></script>
}