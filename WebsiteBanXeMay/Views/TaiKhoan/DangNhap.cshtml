@model WebsiteBanXeMay.Models.ViewModels.DangNhapViewModels
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/dangnhap.css" />
<link rel="stylesheet" href="~/js/dangnhap.js" />
<div class="dangnhap-container">
    <div class="dangnhap-card">
        <!-- Header -->
        <div class="dangnhap-header">
            <h2 class="dangnhap-title">
                <i class="fas fa-sign-in-alt me-3"></i>Đăng nhập
            </h2>
            <p class="mb-0 opacity-90 mt-2" style="font-size: 0.95rem;">Chào mừng quay lại!</p>
        </div>

        <!-- Body -->
        <div class="dangnhap-body">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="DangNhap" method="post">
                <div asp-validation-summary="All" class="text-danger mb-4"></div>

                <!-- Tên đăng nhập -->
                <div class="form-floating mb-4 position-relative">
                    <input asp-for="TenDangNhap" class="form-control" id="TenDangNhap" placeholder="Tên đăng nhập" />
                    <label asp-for="TenDangNhap" class="form-label"></label>
                    <span asp-validation-for="TenDangNhap" class="invalid-feedback"></span>
                </div>

                <!-- Mật khẩu -->
                <div class="form-floating mb-4 position-relative">
                    <input asp-for="MatKhau" class="form-control pe-5" id="MatKhau" type="password" placeholder="Mật khẩu" />
                    <label asp-for="MatKhau" class="form-label"></label>
                    <span asp-validation-for="MatKhau" class="invalid-feedback"></span>
                    <button type="button" class="btn-toggle-password" data-target="#MatKhau" title="Hiện mật khẩu">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>

                <!-- Checkbox -->
                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" id="remember" name="remember">
                    <label class="form-check-label" for="remember">
                        Ghi nhớ đăng nhập
                    </label>
                </div>

                <!-- Button -->
                <button type="submit" class="btn-dangnhap-primary text-white mb-4 fw-semibold">
                    <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                </button>

                <!-- Link đăng ký -->
                <div class="text-center">
                    <p class="mb-0">
                        <small>Chưa có tài khoản? </small>
                        <a asp-controller="TaiKhoan" asp-action="DangKi" class="text-decoration-none fw-semibold">
                            Đăng ký ngay <i class="fas fa-arrow-right ms-1"></i>
                        </a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Toggle password
            document.querySelectorAll('.btn-toggle-password').forEach(btn => {
                btn.addEventListener('click', function() {
                    const target = document.querySelector(this.dataset.target);
                    const icon = this.querySelector('i');
                    if (target.type === 'password') {
                        target.type = 'text';
                        icon.classList.replace('fa-eye', 'fa-eye-slash');
                    } else {
                        target.type = 'password';
                        icon.classList.replace('fa-eye-slash', 'fa-eye');
                    }
                });
            });

            // Auto focus
            document.getElementById('TenDangNhap')?.focus();

            // Enter submit
            document.querySelector('form').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    this.submit();
                }
            });
        });
    </script>
}