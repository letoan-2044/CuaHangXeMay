@model WebsiteBanXeMay.Models.SanPham
@{
    ViewData["Title"] = Model?.TenSanPham ?? "Chi tiết sản phẩm";
}

<div class="container py-5">
@if (Model != null)
{
        <div class="row g-5">
            <!-- 🔥 ẢNH LỚN - ✅ URL FIX -->
            <div class="col-lg-6">
                <img src="@Url.Content(string.IsNullOrEmpty(Model.HinhAnh) ? "~/images/no-image.png" : $"~/images/{Model.HinhAnh}")"
                     class="img-fluid rounded-3 shadow-lg w-100"
                     alt="@Model.TenSanPham"
                     style="max-height: 500px; object-fit: cover;"
                     onerror="this.src='@Url.Content("~/images/no-image.png")'" />
            </div>

            <!-- INFO -->
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4">@Model.TenSanPham</h1>
                <div class="h1 text-danger fw-bold mb-4">@Model.Gia.ToString("N0") VNĐ</div>

                <div class="row mb-4">
                    <div class="col-6">
                        <div class="card border-0 bg-light h-100">
                            <div class="card-body text-center p-3">
                                <i class="fas fa-warehouse text-success fa-2x mb-2"></i>
                                <h5 class="fw-bold">@Model.SoLuongTon</h5>
                                <small>Tồn kho</small>
                            </div>
                        </div>
                    </div>
                    @if (Model.DanhMuc != null)
                    {
                        <div class="col-6">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body text-center p-3">
                                    <i class="fas fa-tag text-info fa-2x mb-2"></i>
                                    <h5 class="fw-bold">@Model.DanhMuc.TenDanhMuc</h5>
                                    <small>Danh mục</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.MoTa))
                {
                    <div class="mb-5">
                        <h3 class="h4 fw-bold mb-3">Thông tin chi tiết</h3>
                        <div class="bg-light p-4 rounded-3">
                            <p class="lead mb-0">@Model.MoTa</p>
                        </div>
                    </div>
                }

                <!-- 🔥 NÚT ACTION -->
                <div class="d-flex gap-3">
                    <a asp-action="Index" class="btn btn-outline-primary btn-lg">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </a>
                    @if (ViewBag.IsLoggedIn == true)
                    {
                        <form asp-action="AddToCart" method="post" style="display:inline;">
                            <input type="hidden" name="maSanPham" value="@ViewBag.MaSanPham" />
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="fas fa-shopping-cart me-2"></i>Thêm giỏ hàng
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
}
else
{
        <div class="alert alert-warning text-center py-5">
            <h2>❌ Sản phẩm không tồn tại!</h2>
            <a asp-action="Index" class="btn btn-primary">← Về danh sách</a>
        </div>
}
    
