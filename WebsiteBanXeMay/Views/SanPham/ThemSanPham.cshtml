@model WebsiteBanXeMay.Models.SanPham
@{
    ViewData["Title"] = ViewBag.Title ?? "Sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool isEdit = Model.MaSanPham > 0;
    string actionName = ViewBag.Action ?? "ThemSanPham";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card shadow-xl border-0">
            <div class="card-header bg-gradient-@(isEdit ? "info" : "success") text-white py-4">
                <div class="d-flex align-items-center">
                    <div class="bg-white bg-opacity-20 rounded-circle p-3 me-3 shadow-sm">
                        <i class="fas fa-@(isEdit ? "edit" : "plus") fs-2 text-white"></i>
                    </div>
                    <div>
                        <h3 class="mb-1 fw-bold">@ViewBag.Title</h3>
                        <small>@(isEdit ? $"ID: {Model.MaSanPham}" : "Tạo sản phẩm mới")</small>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="@actionName" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    @if (isEdit)
                    {
                        <input type="hidden" asp-for="MaSanPham" />
                    }

                    <div class="row g-4">
                        <!-- Cột 1: Thông tin cơ bản -->
                        <div class="col-lg-8">
                            <div class="row g-3">
                                <!-- Tên SP -->
                                <div class="col-12">
                                    <label asp-for="TenSanPham" class="form-label fw-semibold">Tên sản phẩm <span class="text-danger">*</span></label>
                                    <input asp-for="TenSanPham" class="form-control @(ViewData.ModelState["TenSanPham"]?.Errors.Any() == true ? "is-invalid" : "")" />
                                    <span asp-validation-for="TenSanPham" class="text-danger"></span>
                                </div>

                                <!-- Danh mục -->
                                <div class="col-md-6">
                                    <label asp-for="MaDanhMuc" class="form-label fw-semibold">Danh mục <span class="text-danger">*</span></label>
                                    <select asp-for="MaDanhMuc" class="form-select @(ViewData.ModelState["MaDanhMuc"]?.Errors.Any() == true ? "is-invalid" : "")">
                                        <option value="">Chọn danh mục</option>
                                        @if (ViewBag.DanhMucs != null)
                                        {
                                            @foreach (var dm in ViewBag.DanhMucs as List<WebsiteBanXeMay.Models.DanhMuc>)
                                            {
                                                <option value="@dm.MaDanhMuc" selected="@(dm.MaDanhMuc == Model.MaDanhMuc ? "selected" : null)">
                                                    @dm.TenDanhMuc
                                                </option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="MaDanhMuc" class="text-danger"></span>
                                </div>

                                <!-- Giá -->
                                <div class="col-md-6">
                                    <label asp-for="Gia" class="form-label fw-semibold">Giá bán <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text">₫</span>
                                        <input asp-for="Gia" class="form-control @(ViewData.ModelState["Gia"]?.Errors.Any() == true ? "is-invalid" : "")" />
                                    </div>
                                    <span asp-validation-for="Gia" class="text-danger"></span>
                                </div>

                                <!-- Số lượng tồn -->
                                <div class="col-md-6">
                                    <label asp-for="SoLuongTon" class="form-label fw-semibold">Số lượng tồn</label>
                                    <input asp-for="SoLuongTon" class="form-control" />
                                    <span asp-validation-for="SoLuongTon" class="text-danger"></span>
                                </div>

                                <!-- Trạng thái -->
                                <div class="col-md-6">
                                    <label asp-for="TrangThai" class="form-label fw-semibold">Trạng thái</label>
                                    <div class="form-check form-switch">
                                        <input asp-for="TrangThai" class="form-check-input" type="checkbox" />
                                        <label class="form-check-label">
                                            @Html.DisplayNameFor(m => m.TrangThai)
                                        </label>
                                    </div>
                                </div>

                                <!-- Mô tả -->
                                <div class="col-12">
                                    <label asp-for="MoTa" class="form-label fw-semibold">Mô tả</label>
                                    <textarea asp-for="MoTa" rows="4" class="form-control"
                                              placeholder="Mô tả chi tiết sản phẩm..."></textarea>
                                    <span asp-validation-for="MoTa" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Cột 2: Hình ảnh -->
                        <div class="col-lg-4">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0 fw-semibold">
                                        <i class="fas fa-image me-2 text-info"></i>Hình ảnh
                                    </h6>
                                </div>
                                <div class="card-body text-center p-4">
                                    @if (isEdit && !string.IsNullOrEmpty(Model?.HinhAnh))
                                    {
                                        <img id="imgPreview" src="@Model.HinhAnh"
                                             alt="Ảnh hiện tại" class="img-thumbnail mb-3 shadow-sm"
                                             style="max-height: 250px; object-fit: cover;" />
                                        <input type="hidden" name="hinhAnhCu" value="@Model.HinhAnh" />
                                    }
                                    else
                                    {
                                        <div id="imgPreview" class="border-dashed border-3 border-secondary rounded-3 p-5 mb-3 bg-light"
                                             style="height: 250px; display: flex; align-items: center; justify-content: center;">
                                            <div class="text-center">
                                                <i class="fas fa-image fa-3x text-muted mb-2"></i>
                                                <p class="text-muted mb-0">Chọn ảnh sản phẩm</p>
                                            </div>
                                        </div>
                                    }

                                    <input type="file" name="hinhAnh" accept="image/*" class="form-control"
                                           onchange="previewImage(event)" />
                                    <small class="text-muted d-block mt-1">
                                        JPG, PNG | Tối đa 5MB
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Nút hành động -->
                    <div class="row mt-5">
                        <div class="col-12 text-end">
                            <a asp-action="QuanLySanPham" asp-controller="SanPham" class="btn btn-outline-secondary me-2">
                                <i class="fas fa-arrow-left me-1"></i>Quay lại
                            </a>
                            <button type="submit" class="btn btn-@(isEdit ? "info" : "success")">
                                <i class="fas fa-@(isEdit ? "save" : "plus") me-1"></i>
                                @(isEdit ? "Cập nhật" : "Thêm mới")
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(event) {
            const file = event.target.files[0];
            const preview = document.getElementById('imgPreview');

            if (file && preview) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    if (preview) {
                        preview.innerHTML = `<img src="${e.target.result}" class="img-thumbnail shadow-sm" style="max-height: 250px; object-fit: cover; width: 100%;">`;
                    }
                };
                reader.readAsDataURL(file);
            }
        }

        // Auto format giá tiền
                // Auto format giá tiền - REMOVE THIS
        document.addEventListener('DOMContentLoaded', function() {
            const giaInput = document.querySelector('input[name="Gia"]');
            if (giaInput) {
                giaInput.addEventListener('input', function(e) {
                    let value = e.target.value.replace(/[^\d]/g, '');
                    e.target.value = value ? parseInt(value).toLocaleString('vi-VN') : '';             
            }
        });
    </script>
}