@model List<WebsiteBanXeMay.Models.SanPham>
@{
    ViewData["Title"] = "Sản phẩm";
}

<div class="container-fluid py-5 bg-light min-vh-100">
    <!-- Header -->
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-4 fw-bold mb-2">
                <i class="fas fa-motorcycle text-primary me-3"></i>DANH SÁCH XE MÁY
            </h1>
            @if (User.Identity.IsAuthenticated)
            {
                <p class="lead text-success">Xin chào @User.Identity.Name (Khách hàng)</p>
            }
        </div>
    </div>
   
    <!-- 🔥 PRODUCTS GRID -->
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="card h-100 shadow-lg border-0 hover-lift">
                        <!-- Image -->
                        <img src="/images/@item.HinhAnh"
                             class="card-img-top"
                             alt="@item.TenSanPham"
                             style="height: 240px; object-fit: cover;"
                             loading="lazy"
                             onerror="console.log('Image failed: /images/@item.HinhAnh'); this.src='/images/no-image.png';" />

                        <div class="card-body p-4 d-flex flex-column">
                            @if (item.DanhMuc != null)
                            {
                                <span class="badge bg-info mb-3">@item.DanhMuc.TenDanhMuc</span>
                            }
                            <h5 class="card-title fw-bold mb-3">@item.TenSanPham</h5>
                            <div class="h3 text-danger fw-bold mb-4">@item.Gia.ToString("N0")₫</div>

                            <!-- 🔥 BUTTONS FIX - QUAN TRỌNG -->
                            <!-- 🔥 NÚT GIỎ HÀNG - FIX CUỐI CÙNG -->
                            <div class="mt-auto">
                                <a asp-action="Details" asp-route-id="@item.MaSanPham"
                                   class="btn btn-primary w-100 mb-2">
                                    <i class="fas fa-eye me-2"></i>Xem chi tiết
                                </a>

                                @if (ViewBag.IsLoggedIn == true)
                                {
                                    <form asp-controller="SanPham" asp-action="AddToCart" method="post" style="width:100%;">
                                        <input type="hidden" name="maSanPham" value="@item.MaSanPham" />
                                        <input type="hidden" name="tuKhoa" value="@ViewBag.TuKhoa" />
                                        <input type="hidden" name="hangXe" value="@ViewBag.SelectedHangXe" />
                                        <input type="hidden" name="page" value="@ViewBag.CurrentPage" />
                                        <button type="submit" class="btn btn-success w-100">
                                            <i class="fas fa-cart-plus me-2"></i>Thêm giỏ hàng
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <a asp-controller="TaiKhoan" asp-action="DangNhap" class="btn btn-outline-warning w-100">
                                        <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập để mua
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-5">
                    <i class="fas fa-inbox fa-3x mb-3 text-muted"></i>
                    <h3 class="text-muted">Chưa có sản phẩm nào</h3>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .hover-lift {
            transition: all 0.3s ease;
        }

            .hover-lift:hover {
                transform: translateY(-10px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
            }

        .card {
            transition: all 0.3s ease;
        }

        .btn {
            transition: all 0.2s ease;
        }

            .btn:hover {
                transform: translateY(-2px);
            }
    </style>
}

@section Scripts {
    <script>
        // Debug login status
        console.log('User logged in:', @Json.Serialize(User.Identity.IsAuthenticated));
        console.log('User name:', '@User.Identity.Name');
    </script>
}