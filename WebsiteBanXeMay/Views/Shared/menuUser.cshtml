@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@{
    var isLoggedIn = User.Identity.IsAuthenticated;
    var isAdmin = User.IsInRole("Admin");
    var isNhanVien = User.IsInRole("Nhân viên");
    var canManage = isAdmin || isNhanVien;
}

@if (isLoggedIn)
{
    <!-- 👤 ĐÃ ĐĂNG NHẬP -->
    <ul class="navbar-nav">
        <!-- DROPDOWN USER -->
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button"
               data-bs-toggle="dropdown" aria-expanded="false">
                <i class="fas fa-user-circle fs-4 me-2"></i>
                <span class="d-none d-lg-inline">@User.Identity?.Name</span>
                @if (isAdmin)
                {
                    <span class="badge bg-danger ms-1">Admin</span>
                }
                else if (isNhanVien)
                {
                    <span class="badge bg-warning text-dark ms-1">NV</span>
                }
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-lg">
                <li>
                    <h6 class="dropdown-header">
                        <i class="fas fa-user me-2"></i>@User.Identity?.Name
                    </h6>
                </li>
                <li><hr class="dropdown-divider"></li>

                @if (canManage)
                {
                    <!-- 🔥 MENU QUẢN TRỊ -->
                    <li>
                        <h6 class="dropdown-header text-primary">
                            <i class="fas fa-crown me-2"></i>QUẢN LÝ
                        </h6>
                    </li>
                    <li>
                        <a class="dropdown-item" asp-controller="SanPhams" asp-action="AdminIndex">
                            <i class="fas fa-boxes me-2 text-primary"></i>Quản lý sản phẩm
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" asp-controller="DanhMuc" asp-action="Index">
                            <i class="fas fa-list me-2 text-success"></i>Quản lý danh mục
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                }

                <!-- MENU KHÁCH HÀNG -->
                <li>
                    <a class="dropdown-item" asp-controller="DonHang" asp-action="Index">
                        <i class="fas fa-shopping-bag me-2 text-info"></i>Đơn hàng của tôi
                    </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item border-0 bg-transparent w-100 text-start">
                            <i class="fas fa-sign-out-alt me-2 text-danger"></i>Đăng xuất
                        </button>
                    </form>
                </li>
            </ul>
        </li>

        <!-- GIỎ HÀNG -->
        <li class="nav-item">
            <a class="nav-link position-relative" asp-controller="GioHang" asp-action="Index">
                <i class="fas fa-shopping-cart fs-5"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger fs-8">
                    3
                    <span class="visually-hidden">sản phẩm</span>
                </span>
            </a>
        </li>
    </ul>
}
else
{
    <!-- 👋 CHƯA ĐĂNG NHẬP -->
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" asp-controller="Account" asp-action="Login">
                <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Account" asp-action="Register">
                <i class="fas fa-user-plus me-1"></i>Đăng ký
            </a>
        </li>
    </ul>
}