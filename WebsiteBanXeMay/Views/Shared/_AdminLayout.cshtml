<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- AdminLTE CSS -->
    <link href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" rel="stylesheet">
    <style>
        .sidebar {
            background: linear-gradient(180deg, #1e3c72 0%, #2a5298 100%);
        }

        .main-header {
            background: #367fa9;
        }

        .brand-link {
            background: linear-gradient(45deg, #1e3c72, #2a5298) !important;
        }
    </style>
</head>
<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">

        <!-- Navbar ✅ ĐÃ FIX -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav ms-auto">
                <!-- ✅ FIX: ml-auto → ms-auto -->
                @if (Context.Session.GetInt32("MaChucVu") == 1 || Context.Session.GetInt32("MaChucVu") == 2)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link" data-bs-toggle="dropdown" href="#">
                            <i class="fas fa-user-circle"></i>
                            <span class="d-none d-md-inline">@Context.Session.GetString("HoTen")</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-lg-end">
                            <!-- ✅ FIX: Cấu trúc mới -->
                            <li><span class="dropdown-item-text">@Context.Session.GetString("ChucVu")</span></li>  <!-- ✅ FIX: dropdown-item-text -->
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a asp-controller="Admin" asp-action="Index" class="dropdown-item">
                                    <i class="fas fa-tachometer-alt me-2"></i> Dashboard  <!-- ✅ FIX: mr-2 → me-2 -->
                                </a>
                            </li>
                            <li>
                                <a asp-controller="AdminSanPham" asp-action="Index" class="dropdown-item">
                                    <i class="fas fa-boxes me-2"></i> Sản phẩm  <!-- ✅ FIX: mr-2 → me-2 -->
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a asp-controller="TaiKhoan" asp-action="DangXuat" class="dropdown-item">
                                    <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất  <!-- ✅ FIX: mr-2 → me-2 -->
                                </a>
                            </li>
                        </ul>
                    </li>
                }
            </ul>
        </nav>

        <!-- Main Sidebar ✅ ĐÃ FIX -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a href="/" class="brand-link">
                <span class="brand-text font-weight-light">🚀 BanXeMay.vn</span>
            </a>

            <div class="sidebar">
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column nav-child-indent"
                        data-widget="treeview" role="menu" data-accordion="false">
                        <!-- ✅ FIX: Thêm data-accordion -->
                        @if (Context.Session.GetInt32("MaChucVu") == 1 || Context.Session.GetInt32("MaChucVu") == 2)
                        {
                            <li class="nav-item">
                                <a asp-controller="Admin" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-tachometer-alt"></i>
                                    <p>Dashboard</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="AdminSanPham" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-boxes"></i>
                                    <p>Quản lý sản phẩm</p>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- Content Wrapper -->
        <div class="content-wrapper">
            <section class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-6">
                            <h1>@ViewData["Title"]</h1>
                        </div>
                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

        <!-- Scripts ✅ ĐÃ FIX -->
        <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </div>  <!-- ✅ ĐÚNG VỊ TRÍ -->
</body>
</html>