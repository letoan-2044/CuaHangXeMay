<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard - Xe Máy VN</title>
    <link rel="icon" href="~/images/favicon.ico" type="image/x-icon">

    <!-- 🔥 BOOTSTRAP 5.3 + ICONS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- 🔥 PERFECT SCROLLBAR -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.3.0/css/OverlayScrollbars.min.css">

    <!-- 🔥 ADMIN CSS -->
    <link rel="stylesheet" href="~/css/adminlte.min.css">
</head>

<body>
    <!-- 🔥 PAGE LOADER -->
    <div class="page-loader" id="loader">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <!-- 🔥 SIDEBAR -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a href="@Url.Action("Index", "Admin", new { area = "Admin" })" class="logo">
                <i class="fas fa-crown logo-icon"></i>
                <span class="logo-text-full">Xe Máy VN Admin</span>
                <span class="logo-text-mini d-none">XM</span>
            </a>
        </div>

        <nav class="p-3">
            <ul class="nav flex-column">
                <!-- Dashboard -->
                <li class="nav-item">
                    <a class="nav-link active" href="@Url.Action("Index", "Admin", new { area = "Admin" })">
                        <i class="bi bi-speedometer2 nav-icon"></i>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </li>

                <!-- Sản phẩm -->
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("QuanLySanPham", "SanPham", new { area = "Admin" })">
                        <i class="fas fa-boxes-stacked nav-icon"></i>
                        <span class="nav-text">Sản phẩm</span>
                        <span class="badge bg-primary rounded-pill ms-auto">248</span>
                    </a>
                    <ul class="submenu">
                        <li><a class="submenu-link" href="@Url.Action("QuanLySanPham", "SanPham", new { area = "Admin" })">Danh sách</a></li>
                        <li><a class="submenu-link" href="@Url.Action("ThemSanPham", "SanPham", new { area = "Admin" })">Thêm mới</a></li>
                    </ul>
                </li>

                <!-- Đơn hàng -->
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("QuanLyDonHang", "DonHang", new { area = "Admin" })">
                        <i class="fas fa-shopping-bag nav-icon"></i>
                        <span class="nav-text">Đơn hàng</span>
                        <span class="badge bg-success rounded-pill ms-auto">156</span>
                    </a>
                </li>

                <!-- Khách hàng -->
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("QuanLyTaiKhoan", "TaiKhoan", new { area = "Admin" })">
                        <i class="fas fa-users nav-icon"></i>
                        <span class="nav-text">Khách hàng</span>
                        <span class="badge bg-info rounded-pill ms-auto">1,247</span>
                    </a>
                </li>

                <!-- Báo cáo -->
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="fas fa-chart-line nav-icon"></i>
                        <span class="nav-text">Báo cáo</span>
                    </a>
                    <ul class="submenu">
                        <li><a class="submenu-link" href="#">Doanh thu</a></li>
                        <li><a class="submenu-link" href="#">Sản phẩm hot</a></li>
                        <li><a class="submenu-link" href="#">Hành vi KH</a></li>
                    </ul>
                </li>

                <!-- Cài đặt -->
                <li class="nav-item mt-auto">
                    <a class="nav-link" href="#">
                        <i class="fas fa-cog nav-icon"></i>
                        <span class="nav-text">Cài đặt</span>
                    </a>
                </li>
            </ul>
        </nav>
    </div>

    <!-- 🔥 MAIN WRAPPER -->
    <div class="main-wrapper">
        <!-- 🔥 TOPBAR -->
        <header class="topbar">
            <div class="topbar-content">
                <!-- Left -->
                <div class="d-flex align-items-center">
                    <!-- Toggle -->
                    <button class="sidebar-toggle me-3" id="sidebarToggle">
                        <i class="fas fa-bars fs-5"></i>
                    </button>

                    <!-- Breadcrumb -->
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb breadcrumb-sm mb-0">
                            <li class="breadcrumb-item"><a href="#"><i class="fas fa-home me-1"></i></a></li>
                            <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
                        </ol>
                    </nav>
                </div>

                <!-- Right -->
                <div class="d-flex align-items-center gap-2">
                    <!-- Notifications -->
                    <div class="position-relative">
                        <button class="btn btn-outline-secondary btn-sm px-3" data-bs-toggle="dropdown">
                            <i class="fas fa-bell"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                3
                            </span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end shadow-lg" style="width: 350px;">
                            <h6 class="dropdown-header">Thông báo mới</h6>
                            <a class="dropdown-item" href="#">
                                <div class="d-flex">
                                    <div class="flex-shrink-0">
                                        <i class="fas fa-shopping-cart text-success fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <strong>Đơn hàng mới #DH123</strong>
                                        <small class="d-block text-muted">2 phút trước</small>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>

                    <!-- User -->
                    @{
                        var userName = Context.Session.GetString("HoTen") ?? "Admin";
                        var role = Context.Session.GetString("ChucVu") ?? "Admin";
                    }
                    <div class="dropdown">
                        <a class="dropdown-toggle d-flex align-items-center text-decoration-none p-2"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <div class="user-avatar bg-gradient-primary text-white me-2">
                                <i class="fas fa-user fs-5"></i>
                            </div>
                            <div class="d-none d-md-block text-truncate" style="max-width: 150px;">
                                <div class="fw-semibold small">@userName</div>
                                <small class="text-muted">@role</small>
                            </div>
                        </a>
                        <ul class="dropdown-menu user-dropdown shadow-xl">
                            <li>
                                <div class="dropdown-item-text px-4 py-3 text-center">
                                    <div class="user-avatar-large bg-gradient-primary text-white mx-auto mb-2">
                                        <i class="fas fa-crown fs-3"></i>
                                    </div>
                                    <h6 class="mb-1">@userName</h6>
                                    <small class="text-muted">@role</small>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("ThongTin", "TaiKhoan")">
                                    <i class="fas fa-user-circle me-3 text-primary"></i>
                                    Hồ sơ
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("DoiMatKhau", "TaiKhoan")">
                                    <i class="fas fa-lock me-3 text-warning"></i>
                                    Đổi mật khẩu
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="TaiKhoan" asp-action="DangXuat" method="post" class="px-3">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger fw-medium w-100 text-start">
                                        <i class="fas fa-sign-out-alt me-3"></i>
                                        Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </header>

        <!-- 🔥 CONTENT -->
        <main class="content">
            @RenderBody()
        </main>
    </div>

    <!-- 🔥 JAVASCRIPT -->
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Perfect Scrollbar -->
    <script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.3.0/js/OverlayScrollbars.min.js"></script>

    <!-- Chart.js (cho Dashboard) -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>

    <!-- 🔥 ADMIN JS -->
    <script src="~/js/adminlte.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>